{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "DevForge: Build",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-File",
        "${workspaceFolder}\\build.ps1"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "DevForge: Build and Test",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-File",
        "${workspaceFolder}\\build.ps1",
        "-Test"
      ],
      "group": "test",
      "problemMatcher": []
    }
  ]
}
